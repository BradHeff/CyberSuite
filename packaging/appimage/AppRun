#!/bin/sh
# AppRun for CyberSuite. Runs the bundled package with the system Python 3.
# (Python's tkinter cannot be pip-bundled, so the host still needs python3 + Tk;
#  ttkbootstrap IS bundled, so the themed GUI works out of the box.)
HERE="$(dirname "$(readlink -f "$0")")"
export PYTHONPATH="${HERE}/usr/lib/cybersuite:${PYTHONPATH}"

PY=python3
command -v "$PY" >/dev/null 2>&1 || PY=python
if ! command -v "$PY" >/dev/null 2>&1; then
    echo "CyberSuite needs Python 3 installed on this system." >&2
    exit 1
fi

if ! "$PY" -c "import tkinter" >/dev/null 2>&1; then
    echo "NOTE: tkinter is missing; starting the CLI instead of the GUI." >&2
    echo "  Debian/Ubuntu: sudo apt install python3-tk" >&2
    echo "  Fedora:        sudo dnf install python3-tkinter" >&2
    exec "$PY" -m cybersuite --cli "$@"
fi

exec "$PY" -m cybersuite "$@"
